# =============================================================================
# PlannerCore — Konfiguration
# =============================================================================
# Dieser Service ist Teil des Tsunami Events Cores-Ökosystems.
# Auth erfolgt über das cores-dashboard (cores_token Cookie).
# =============================================================================

# ----- Server -----
PORT=8080
# Öffentliche URL (für E-Mail-Links, ohne / am Ende)
APP_URL=http://localhost:8080

# ----- Authentifizierung (Cores SSO) -----
# WICHTIG: Muss mit dem Wert in cores-dashboard übereinstimmen!
CORES_JWT_SECRET=bitte-durch-langen-zufallswert-ersetzen

# ----- Datenbank (geteilte PostgreSQL-Instanz) -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rentalcore
DB_USER=rentalcore
DB_PASSWORD=bitte-aendern

# ----- E-Mail-Benachrichtigungen über Microsoft 365 -----
# Provider: graph (empfohlen) | smtp | console (nur Log-Ausgabe)
MAIL_PROVIDER=console

# Variante A: Microsoft Graph API
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
MAIL_SENDER=

# Variante B: SMTP AUTH über Office 365
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
